# White-label configuration example
# Copy this file to .env and adjust the values for your client

# App Branding
EXPO_PUBLIC_APP_NAME="Custom App Name"
EXPO_PUBLIC_APP_SLUG="custom-app-slug"
EXPO_PUBLIC_APP_SCHEME="customapp"

# App Assets (Paths relative to the project root)
EXPO_PUBLIC_APP_ICON="./assets/icon.png"
EXPO_PUBLIC_APP_ADAPTIVE_ICON="./assets/adaptive-icon.png"
EXPO_PUBLIC_SPLASH_IMAGE="./assets/splash.png"
EXPO_PUBLIC_SPLASH_BACKGROUND_COLOR="#ffffff"

# App Colors
EXPO_PUBLIC_PRIMARY_COLOR="#1FB6FF"
EXPO_PUBLIC_SECONDARY_COLOR="#0084FF"
EXPO_PUBLIC_ACCENT_COLOR="#FF3B30"

# Identifiers
EXPO_PUBLIC_IOS_BUNDLE_IDENTIFIER="com.custom.app"
EXPO_PUBLIC_ANDROID_PACKAGE="com.custom.app"

# Backend Configuration
EXPO_PUBLIC_BACKEND_URL="https://api.yourbackend.com"

# Services
EXPO_PUBLIC_IOS_GOOGLE_SERVICES_FILE="./GoogleService-Info.plist"
EXPO_PUBLIC_ANDROID_GOOGLE_SERVICES_FILE="./google-services.json"
EXPO_PUBLIC_SENTRY_PROJECT_NAME="your-sentry-project"
EXPO_PUBLIC_SENTRY_ORG_NAME="your-sentry-org"
