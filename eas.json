{
  "cli": {
    "version": ">= 12.3.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "android": {
        "buildType": "apk"
      },
      "env": {
        "SENTRY_DISABLE_AUTO_UPLOAD": "true",
        "EXPO_USE_COMMUNITY_AUTOLINKING": "1"
      },
      "prebuildCommand": "rm -rf android && npx expo prebuild --platform android"
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "SENTRY_DISABLE_AUTO_UPLOAD": "true",
        "EXPO_USE_COMMUNITY_AUTOLINKING": "1"
      },
      "prebuildCommand": "rm -rf android && npx expo prebuild --platform android"
    }
  },
  "submit": {
    "production": {
      "android": {
        "track": "internal"
      }
    }
  }
}
